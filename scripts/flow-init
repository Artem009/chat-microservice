#!/bin/bash

# Wogi Flow - Initialize Workflow
# This script redirects to AI-driven setup

WORKFLOW_DIR=".workflow"

# Colors
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# Check if already initialized
if [ -f "$WORKFLOW_DIR/config.json" ]; then
    echo -e "${CYAN}WogiFlow:${NC} Already initialized."
    echo ""
    echo "Run ${YELLOW}flow status${NC} to see project state."
    echo "Run ${YELLOW}flow health${NC} to check workflow health."
    exit 0
fi

# Check if pending-setup.json exists (postinstall created it)
if [ -f "$WORKFLOW_DIR/state/pending-setup.json" ]; then
    echo -e "${CYAN}WogiFlow:${NC} Setup pending."
    echo ""
fi

# Direct users to AI assistant
echo -e "${CYAN}в•”в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•—${NC}"
echo -e "${CYAN}в•‘${NC}                  ${GREEN}WogiFlow Setup${NC}                             ${CYAN}в•‘${NC}"
echo -e "${CYAN}в• в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•Ј${NC}"
echo -e "${CYAN}в•‘${NC}                                                              ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}  WogiFlow setup is handled by your AI assistant.            ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}                                                              ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}  ${YELLOW}Start your AI assistant:${NC}                                  ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}                                                              ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}    ${GREEN}claude${NC}      (Claude Code)                               ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}                                                              ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}  Then say: ${YELLOW}\"setup wogiflow\"${NC} or run ${YELLOW}/wogi-init${NC}             ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}                                                              ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}  The AI will guide you through:                              ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}    вЂў Project name confirmation                               ${CYAN}в•‘${NC}"
echo -e "${CYAN}в•‘${NC}    вЂў Tech stack selection                                    ${CYAN}в•‘${NC}"
